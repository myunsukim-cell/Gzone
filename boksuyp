    <script>
        // 페이지 로드 시 체크인 팝업 자동 표시
        window.onload = function() {
            // 실제로는 체크인 완료 여부를 서버에서 확인
            const isCheckedIn = localStorage.getItem('todayCheckedIn');
            if (!isCheckedIn || isCheckedIn !== new Date().toDateString()) {
                document.getElementById('checkinPopup').style.display = 'block';
                document.getElementById('checkinOverlay').style.display = 'block';
            } else {
                updateCheckinStatus(true);
            }
        };

        // 슬라이더 값 업데이트
        document.getElementById('taskCompletion').oninput = function() {
            document.getElementById('taskValue').textContent = this.value + '%';
        };

        // 학습 패턴 선택 시 요일별 입력 표시/숨김
        document.querySelectorAll('input[name="studyPattern"]').forEach(radio => {
            radio.addEventListener('change', function() {
                const weekInputs = document.getElementById('weekDayInputs');
                if (this.value === 'specific') {
                    weekInputs.classList.add('show');
                } else {
                    weekInputs.classList.remove('show');
                }
            });
        });

        // 척도 버튼 선택
        document.querySelectorAll('.scale-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                this.parentElement.querySelectorAll('.scale-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
            });
        });

        // 태그 버튼 선택
        document.querySelectorAll('.tag-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                this.classList.toggle('active');
            });
        });

        // 체크인 완료
        function submitCheckin() {
            // 실제로는 서버에 데이터 전송
            const formData = gatherCheckinData();
            console.log('체크인 데이터:', formData);
            
            // 로컬스토리지에 완료 표시
            localStorage.setItem('todayCheckedIn', new Date().toDateString());
            
            closeCheckin();
            updateCheckinStatus(true);
            alert('오늘의 학습 체크인이 완료되었습니다!\n선생님께 전달되었습니다.');
        }

        // 체크인 데이터 수집
        function gatherCheckinData() {
            const data = {
                taskCompletion: document.getElementById('taskCompletion').value,
                studyPattern: document.querySelector('input[name="studyPattern"]:checked')?.value,
                weeklyStudyTimes: {},
                taskAmount: document.querySelector('.scale-btn.active')?.dataset.value,
                extraStudy: [],
                difficultParts: {
                    tags: [],
                    details: document.querySelector('.question-block:nth-child(6) textarea').value
                },
                todayGoal: document.querySelector('.question-block:nth-child(7) textarea').value,
                incompleteReasons: [],
                studyPlan: {
                    today: {
                        time: document.querySelector('.plan-item:first-child .plan-time').value,
                        content: document.querySelector('.plan-item:first-child .plan-content').value
                    },
                    tomorrow: {
                        time: document.querySelector('.plan-item:last-child .plan-time').value,
                        content: document.querySelector('.plan-item:last-child .plan-content').value
                    }
                },
                teacherCheck: document.querySelector('input[name="teacherCheck"]:checked')?.value
            };

            // 요일별 학습시간 수집
            if (data.studyPattern === 'specific') {
                document.querySelectorAll('.day-time').forEach((input, index) => {
                    const days = ['월', '화', '수', '목', '금', '토', '일'];
                    if (input.value) {
                        data.weeklyStudyTimes[days[index]] = input.value;
                    }
                });
            }

            // 추가 학습 활동 수집
            document.querySelectorAll('.question-block:nth-child(5) input[type="checkbox"]:checked').forEach(cb => {
                data.extraStudy.push(cb.value);
            });

            // 어려운 부분 태그 수집
            document.querySelectorAll('.tag-btn.active').forEach(tag => {
                data.difficultParts.tags.push(tag.dataset.tag);
            });

            // 과제 미달 이유 수집
            document.querySelectorAll('.question-block:nth-child(8) input[type="checkbox"]:checked').forEach(cb => {
                data.incompleteReasons.push(cb.value);
            });

            return data;
        }

        // 체크인 상태 업데이트
        function updateCheckinStatus(completed) {
            const statusDiv = document.getElementById('checkinStatus');
            if (completed) {
                statusDiv.classList.remove('pending');
                statusDiv.innerHTML = '<h4>✅ 오늘의 학습 체크인 완료</h4><p>1교시 준비가 완료되었습니다!</p>';
            } else {
                statusDiv.classList.add('pending');
            }
        }

        // 체크인 팝업 열기
        function openCheckin() {
            document.getElementById('checkinPopup').style.display = 'block';
            document.getElementById('checkinOverlay').style.display = 'block';
        }

        // 체크인 팝업 닫기
        function closeCheckin() {
            document.getElementById('checkinPopup').style.display = 'none';
            document.getElementById('checkinOverlay').style.display = 'none';
        }

        // 기존 함수들...
        function selectUnit(unitId) {
            document.querySelectorAll('.unit-item').forEach(item => {
                item.classList.remove('active');
            });
            event.target.classList.add('active');
            updateStageStatus(unitId);
        }
        
        function openStage(stage) {
            console.log(`${stage}단계 학습 시작`);
        }
        
        function switchPeriod(period) {
            document.querySelectorAll('.period-tab').forEach(tab => {
                tab.classList.remove('active');
            });
            document.querySelectorAll('.period-tab')[period-1].classList.add('active');
            
            document.querySelectorAll('.test-result-list').forEach(list => {
                list.classList.remove('active');
            });
            document.getElementById(`period-${period}`).classList.add('active');
        }
        
        function showTestDetail(testName, score, period) {
            alert(`${testName} 상세 결과: ${score}점`);
        }
        
        function savePlan() {
            alert('다음 주 학습 계획이 저장되었습니다.\n선생님께 전달됩니다.');
        }
          
        function continueStudy() {
            console.log('4단계 학습 계속');
        }
        
        function viewProgress() {
